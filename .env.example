# ---- Chain RPCs (BNB mainnet for SIGNALS, testnet for EXECUTION) ----
BSC_RPC_HTTP_1=https://bsc-dataseed1.binance.org
BSC_RPC_HTTP_2=https://rpc.ankr.com/bsc
BSC_RPC_WS=wss://bsc-rpc.publicnode.com
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545

# ---- Infra ----
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://pancake:pancake@localhost:5432/pancakeflow   # optional; snapshots skipped if unset

# ---- Data sources ----
# The Graph decentralized network needs an API key; leave unset to fall back to static pool config.
SUBGRAPH_URL_V2=
BINANCE_API=https://api.binance.com

# ---- Tuning ----
WHALE_USD_THRESHOLD=50000
SNAPSHOT_INTERVAL_MS=15000
GAS_POLL_MS=5000
ORACLE_POLL_MS=5000
CEX_POLL_MS=5000
CATALOG_POLL_MS=60000

# ---- Agents / execution (P3-P7) ----
EXEC_MODE=paper                 # paper | testnet | live
RISK_PROFILE=moderate           # conservative | moderate | aggressive
CAPITAL_USD=10000
MIN_PROFIT_BPS=10
ANTHROPIC_API_KEY=              # optional: enables LLM confidence + NL fallback
QDRANT_URL=                     # optional: enables vector memory (else in-memory)
# on-chain execution (testnet/live only):
EXECUTOR_PK=
ARB_EXECUTOR_ADDR=
PRIVATE_RPC=                    # MEV-protected submit endpoint
NEXT_PUBLIC_API=http://localhost:8000
